{
  "rewrites": [
    { "source": "/", "destination": "/altsrc-repo/altstore.json" },
    { "source": "/altstore.json", "destination": "/altsrc-repo/altstore.json" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
